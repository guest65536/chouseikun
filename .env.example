# このファイルは接続文字列の「見本」です（実際の値は書かない / gitに含めてOK）。
# 開発を始める人は、このファイルをコピーして .env を作り、Neon の値を入れてください。
#   cp .env.example .env

# Neon Pooled 接続（アプリ実行時に使用。ホスト名に "-pooler" が入る）
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Neon Direct 接続（マイグレーション時に使用。"-pooler" なし）
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Resend の APIキー（回答通知メールに使用。https://resend.com で取得）
# 未設定でもアプリは動く（通知メールがスキップされるだけ）
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# 送信元アドレス（任意）。独自ドメインを Resend で認証したら設定する。
# 未設定だと Resend の共有送信元 onboarding@resend.dev を使う。
# EMAIL_FROM="調整くん <noreply@あなたのドメイン>"
